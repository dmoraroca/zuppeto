{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build api (local)",
      "type": "shell",
      "command": "dotnet build \"${workspaceFolder}/src/Backend/Api/Api.csproj\" -c Debug",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "docker up all",
      "type": "shell",
      "command": "docker compose up -d db rabbitmq api web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "docker build all",
      "type": "shell",
      "command": "docker compose build api web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "docker up db",
      "type": "shell",
      "command": "docker compose up -d db",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "docker up api",
      "type": "shell",
      "command": "docker compose up -d api",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "docker up web",
      "type": "shell",
      "command": "docker compose up -d web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "wait api ready",
      "type": "shell",
      "command": "bash \"${workspaceFolder}/.vscode/wait-api-ready.sh\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "wait web ready",
      "type": "shell",
      "command": "bash -lc 'for i in $(seq 1 120); do if curl -fsS http://localhost:4200 >/dev/null 2>&1; then exit 0; fi; sleep 2; done; echo \"Web no ha quedat llesta a :4200\"; exit 1'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "install vsdbg (api)",
      "type": "shell",
      "command": "docker exec -i yeppet-api bash -lc 'rm -rf /vsdbg && mkdir -p /vsdbg && curl -sSL https://aka.ms/getvsdbgsh | bash /dev/stdin -v latest -l /vsdbg'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "api up + ready + vsdbg",
      "dependsOn": [
        "docker up api",
        "wait api ready",
        "install vsdbg (api)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "web up + ready",
      "dependsOn": [
        "docker up web",
        "wait web ready"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "stack up + ready + vsdbg",
      "dependsOn": [
        "docker up all",
        "wait api ready",
        "wait web ready",
        "install vsdbg (api)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "docker down",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    }
  ]
}
