{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "YepPet API (local, F5)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build api (local)",
      "program": "${workspaceFolder}/src/Backend/Api/bin/Debug/net10.0/Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Backend/Api",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5211"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Docker: DB",
      "type": "node-terminal",
      "request": "launch",
      "command": "echo 'yeppet-db disponible a localhost:5433'",
      "preLaunchTask": "docker up db"
    },
    {
      "name": "Docker: API (Attach)",
      "type": "coreclr",
      "request": "attach",
      "requireExactSource": false,
      "processId": "1",
      "pipeTransport": {
        "pipeProgram": "docker",
        "pipeArgs": [
          "exec",
          "-i",
          "yeppet-api"
        ],
        "debuggerPath": "/vsdbg/vsdbg",
        "pipeCwd": "${workspaceFolder}",
        "quoteArgs": false
      },
      "sourceFileMap": {
        "/app": "${workspaceFolder}"
      },
      "preLaunchTask": "api up + ready + vsdbg"
    },
    {
      "name": "Docker: API (Attach, from stack)",
      "type": "coreclr",
      "request": "attach",
      "requireExactSource": false,
      "processId": "1",
      "pipeTransport": {
        "pipeProgram": "docker",
        "pipeArgs": [
          "exec",
          "-i",
          "yeppet-api"
        ],
        "debuggerPath": "/vsdbg/vsdbg",
        "pipeCwd": "${workspaceFolder}",
        "quoteArgs": false
      },
      "sourceFileMap": {
        "/app": "${workspaceFolder}"
      }
    },
    {
      "name": "Docker: Swagger",
      "type": "node-terminal",
      "request": "launch",
      "command": "xdg-open http://localhost:5211/swagger/index.html",
      "preLaunchTask": "api up + ready + vsdbg"
    },
    {
      "name": "Docker: Swagger (from stack)",
      "type": "node-terminal",
      "request": "launch",
      "command": "xdg-open http://localhost:5211/swagger/index.html"
    },
    {
      "name": "Docker: Web (Debug)",
      "type": "node-terminal",
      "request": "launch",
      "command": "xdg-open http://localhost:4200",
      "preLaunchTask": "web up + ready"
    },
    {
      "name": "Docker: Web (Debug, Brave)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/src/Web",
      "runtimeExecutable": "/usr/bin/brave-browser",
      "runtimeArgs": [
        "--new-window",
        "--user-data-dir=/tmp/brave-codex",
        "--no-first-run"
      ],
      "preLaunchTask": "web up + ready"
    },
    {
      "name": "Docker: Web (Debug, from stack)",
      "type": "node-terminal",
      "request": "launch",
      "command": "xdg-open http://localhost:4200"
    },
    {
      "name": "Docker: Web (Debug, Brave, from stack)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/src/Web",
      "runtimeExecutable": "/usr/bin/brave-browser",
      "runtimeArgs": [
        "--new-window",
        "--user-data-dir=/tmp/brave-codex",
        "--no-first-run"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Docker: API + Swagger (Attach)",
      "configurations": [
        "Docker: API (Attach)",
        "Docker: Swagger"
      ],
      "stopAll": false
    },
    {
      "name": "Docker: API + Web (Attach)",
      "configurations": [
        "Docker: API (Attach)",
        "Docker: Web (Debug)"
      ],
      "stopAll": false
    },
    {
      "name": "Docker: Stack completa (Attach)",
      "preLaunchTask": "stack up + ready + vsdbg",
      "configurations": [
        "Docker: API (Attach, from stack)",
        "Docker: Web (Debug, from stack)",
        "Docker: Swagger (from stack)"
      ],
      "stopAll": false
    }
  ]
}
